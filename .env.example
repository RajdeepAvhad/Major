# EatRight Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# NeonDB PostgreSQL Connection String (Production)
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
# Get this from your NeonDB dashboard: https://console.neon.tech/
# Example: postgresql://user:password@ep-cool-darkness-123456.us-east-2.aws.neon.tech/eatright?sslmode=require
DATABASE_URL=

# Leave DATABASE_URL empty to use SQLite for local development
# SQLite will be used automatically if DATABASE_URL is not set


# ============================================================================
# AI CHATBOT CONFIGURATION (Optional)
# ============================================================================

# OpenAI API Configuration (for chatbot)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq API Configuration (alternative chatbot backend - FREE tier available)
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Google Custom Search (for image search - optional)
# Get API key from: https://console.cloud.google.com/apis/credentials
# Get CSE ID from: https://programmablesearchengine.google.com/
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Spoonacular API key for food image fallback
# Example: SPOONACULAR_KEY=your_spoonacular_api_key_here
SPOONACULAR_KEY=


# ============================================================================
# DJANGO CONFIGURATION
# ============================================================================

# Django Secret Key (IMPORTANT: Change this in production!)
# Generate a new one: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=l#()$jrfbxp-k_9!_^!uz(=9u^q6mfp(=2(m_7pu5xw4v@ou8p

# Debug mode (set to False in production)
DEBUG=True

# Allowed hosts (comma-separated, required in production)
# Example: ALLOWED_HOSTS=eatright.com,www.eatright.com
ALLOWED_HOSTS=localhost,127.0.0.1


# ============================================================================
# NEONDB SETUP INSTRUCTIONS
# ============================================================================

# 1. Sign up at https://neon.tech/
# 2. Create a new project (select region closest to your users)
# 3. Create a database named "eatright" (or your preferred name)
# 4. Copy the connection string from the dashboard
# 5. Paste it as DATABASE_URL above
# 6. Make sure it includes ?sslmode=require at the end
#
# Example connection string:
# postgresql://eatright_user:AbCdEf123456@ep-cool-darkness-123456.us-east-2.aws.neon.tech/eatright?sslmode=require
#
# Connection string format breakdown:
# postgresql://     - Protocol
# username          - Your NeonDB username
# :password         - Your NeonDB password
# @host             - NeonDB host (e.g., ep-xxx.region.aws.neon.tech)
# /database         - Database name
# ?sslmode=require  - SSL mode (required for NeonDB)


# ============================================================================
# MIGRATION STEPS
# ============================================================================

# After setting DATABASE_URL:
# 1. Install dependencies: pip install -r requirements.txt
# 2. Run migrations: python manage.py migrate
# 3. Load initial data: python manage.py load_initial_data
# 4. Create superuser: python manage.py createsuperuser
# 5. Run server: python manage.py runserver


# ============================================================================
# NOTES
# ============================================================================

# - The app will work without AI API keys (uses built-in knowledge base)
# - NeonDB free tier includes: 0.5 GB storage, 1 compute unit
# - Always use environment variables for sensitive data
# - Never commit .env file to version control (it's in .gitignore)
